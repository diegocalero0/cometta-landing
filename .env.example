# ============================================================
# Cometta Landing — variables de entorno
# Copia este archivo a .env y ajusta los valores.
# ============================================================

# --- Base de datos PostgreSQL ---
# La BD corre en el contenedor "cometta_production_database" en la red
# "cometta_shared_network". (Por ahora la landing NO la usa, pero el pool
# de conexión queda listo para el futuro.)
#
# DENTRO de Docker (compose unido a esa red): host = nombre del servicio
# "postgres" y puerto INTERNO 5432.
DATABASE_URL=postgresql://cometta:CONTRASENA@postgres:5432/cometta_db
#
# En local (npm run dev, fuera de Docker): usa localhost y el puerto
# publicado por la BD (5434 según su compose):
# DATABASE_URL=postgresql://cometta:CONTRASENA@localhost:5434/cometta_db
